# ─── Database ────────────────────────────────────────────────
# Neon Postgres connection string (with sslmode=require)
DATABASE_URL=

# ─── NextAuth ────────────────────────────────────────────────
# Random 32+ char secret (openssl rand -base64 32)
AUTH_SECRET=
# Production URL, e.g. https://www.veretennikov.info
AUTH_URL=

# ─── Resend (magic link + brief notifications) ───────────────
# https://resend.com/api-keys
AUTH_RESEND_KEY=
# Verified sender address (until domain verified, use onboarding@resend.dev)
EMAIL_FROM="Veretennikov Studio <onboarding@resend.dev>"

# ─── Telegram brief notifications ────────────────────────────
# 1. Create bot via @BotFather, save the token here
# 2. Send any message to the bot, then GET
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat.id
# If both vars are empty, Telegram notifications are silently skipped
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Cloudflare R2 (poster uploads) ──────────────────────────
# Setup:
#   1. Cloudflare dashboard → R2 → создать bucket (например veretennikov-media)
#   2. R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
#   3. Settings бакета → Public Access → Connect a custom domain
#      (рекомендуется, например media.veretennikov.info), либо включить r2.dev
#   4. Account ID — копируется из верхнего правого угла Cloudflare dashboard
#   5. После настройки добавь свой R2 публичный домен в next.config.ts → images.remotePatterns
# Если переменные не заданы — file upload в админке отключается, остаётся только ручной URL.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
