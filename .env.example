# ─── Database ────────────────────────────────────────────────
# Neon Postgres connection string (with sslmode=require)
DATABASE_URL=

# ─── NextAuth ────────────────────────────────────────────────
# Random 32+ char secret (openssl rand -base64 32)
AUTH_SECRET=
# Production URL, e.g. https://www.veretennikov.info
AUTH_URL=

# ─── Resend (magic link + brief notifications) ───────────────
# https://resend.com/api-keys
AUTH_RESEND_KEY=
# Verified sender address (until domain verified, use onboarding@resend.dev)
EMAIL_FROM="Veretennikov Studio <onboarding@resend.dev>"

# ─── Telegram brief notifications ────────────────────────────
# 1. Create bot via @BotFather, save the token here
# 2. Send any message to the bot, then GET
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat.id
# If both vars are empty, Telegram notifications are silently skipped
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
