generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CaseType {
  VIDEO
  AI
  SYNTHESIS
}

model Case {
  id          String   @id @default(cuid())
  slug        String   @unique
  client      String
  title       String
  description String
  type        CaseType
  year        Int
  services    String[]
  challenge   String?
  solution    String?
  outcome     String?
  videoId     String?
  isPublic    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}
